# SQLite file. On Railway put this on the attached Volume (mounted at /data)!
DB_PATH=data/tracker.sqlite

# network = all lines (default; costs the same to run), line37 = corridor only.
# Or override the points directly: SWEEP_POINTS=48.2235,17.0445;48.210,17.045
COVERAGE=network
#SWEEP_POINTS=

# Sweep cadence. Vehicles report ~every 2 min; faster polling only duplicates.
SWEEP_INTERVAL_S=120
INTER_POINT_DELAY_S=1.0

# Overnight pause (local time); set both empty to run 24/7.
PAUSE_FROM=00:30
PAUSE_TO=04:30

# GTFS feed pointer (may move — the stable landing is data.bratislava.sk).
GTFS_URL=https://www.arcgis.com/sharing/rest/content/items/aba12fd2cbac4843bc7406151bc66106/data
GTFS_REFRESH_DAYS=7

# imhd.sk výprava (public page; the /rt/ endpoints are login-gated — never used).
VYPRAVA_URL=https://imhd.sk/ba/vyprava
VYPRAVA_FETCH_HOUR=20

# Matching / analysis tunables
MATCH_TOLERANCE_S=600
MAX_PLAUSIBLE_DELAY_MIN=90
MIN_PLAUSIBLE_DELAY_MIN=-15
ON_TIME_THRESHOLD_MIN=2
MISSED_WINDOW_BEFORE_MIN=5
MISSED_WINDOW_AFTER_MIN=25

TRACKER_TZ=Europe/Bratislava
#USER_AGENT=idsbk-delay-tracker/0.1 (personal punctuality research)
